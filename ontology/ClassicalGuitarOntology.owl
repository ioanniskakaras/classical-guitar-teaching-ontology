        <Literal xml:lang="el">Περίοδος Μπαρόκ</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#BaroquePeriod_Ind</IRI>
        <Literal xml:lang="el">Αναφέρεται στην περίοδο του Μπαρόκ (περ. 1600–1750), σημαντική για το κιθαριστικό ρεπερτόριο και την εξέλιξη των τεχνικών</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#BaroquePeriod_Ind</IRI>
        <Literal xml:lang="en">Baroque Period</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
