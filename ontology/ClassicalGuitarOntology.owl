    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Bridge</IRI>
        <Literal xml:lang="el">Γέφυρα – μεταφέρει τη δόνηση των χορδών στο σώμα της κιθάρας.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Bridge</IRI>
        <Literal xml:lang="en">Bridge</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#prefLabel"/>
        <IRI>#Bridge_Ind</IRI>
        <Literal xml:lang="el">Γέφυρα (Κάτω καβαλάρης)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Bridge_Ind</IRI>
        <Literal xml:lang="el">Η γέφυρα είναι το μέρος της κιθάρας όπου στερεώνονται οι χορδές στο σώμα και μεταδίδεται ο ήχος στο καπάκι</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Bridge_Ind</IRI>
        <Literal xml:lang="en">Guitar Bridge</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#prefLabel"/>
        <IRI>#ClassicalGuitar_Ind</IRI>
        <Literal xml:lang="el">Κλασική Κιθάρα</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ClassicalGuitar_Ind</IRI>
        <Literal xml:lang="el">Η κλασική κιθάρα είναι το κύριο όργανο της μελέτης και ερμηνείας του κλασικού ρεπερτορίου, με νάιλον χορδές</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
