        <IRI>#Body</IRI>
        <Literal xml:lang="el">Σώμα</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Body</IRI>
        <Literal xml:lang="el">Σώμα – το κυρίως ηχητικό μέρος της κιθάρας.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Body</IRI>
        <Literal xml:lang="en">Body</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#prefLabel"/>
        <IRI>#BodyPosture</IRI>
        <Literal xml:lang="el">Στάση σώματος</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#BodyPosture</IRI>
        <Literal xml:lang="el">Ορθή φυσική θέση του σώματος κατά τη διδασκαλία.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#BodyPosture</IRI>
        <Literal xml:lang="en">Body Posture</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#prefLabel"/>
        <IRI>#Body_Ind</IRI>
        <Literal xml:lang="el">Σώμα Κιθάρας</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Body_Ind</IRI>
        <Literal xml:lang="el">Το κύριο ηχείο της κιθάρας, υπεύθυνο για τον ηχητικό όγκο και τον χαρακτήρα του ήχου</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
