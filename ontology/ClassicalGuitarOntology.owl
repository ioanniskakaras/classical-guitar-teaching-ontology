    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#AcousticGuitar_Ind</IRI>
        <Literal xml:lang="el">Κιθάρα με μεταλλικές χορδές, κατάλληλη για ποικίλα μουσικά είδη</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#AcousticGuitar_Ind</IRI>
