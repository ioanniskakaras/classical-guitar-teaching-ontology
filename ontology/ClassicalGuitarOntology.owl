    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ClassicalPeriod_Ind</IRI>
        <Literal xml:lang="el">Αναφέρεται στην Κλασική Περίοδο (περ. 1750–1820), με αντιπροσωπευτικά έργα που συχνά διδάσκονται στην κιθάρα</Literal>
    </AnnotationAssertion>
