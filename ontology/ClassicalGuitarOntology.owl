    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#LO_1_3_1</IRI>
        <Literal xml:lang="el">Γνωριμία με τα μέρη της κιθάρας και των βασικών λειτουργιών τους, καθώς και με τα βασικά είδη κιθάρας</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
